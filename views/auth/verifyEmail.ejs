<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="w-full max-w-md px-8">

    <div class="mb-10">
      <p class="text-xs uppercase tracking-widest text-gray-400 mb-2">Forgot Password</p>
      <h1 class="text-4xl font-semibold text-gray-900">Reset link</h1>
    </div>

    <form id="email-form" class="space-y-7">

      <div>
        <label for="email" class="block text-xs font-medium uppercase tracking-wider text-gray-800 mb-2">Email</label>
        <div class="relative">
          <i class="fa-solid fa-at absolute left-3 top-1/2 -translate-y-1/2 text-gray-800 text-sm"></i>
          <input id="email" type="email" name="email" placeholder="you@example.com" class="w-full border-b border-gray-400 bg-transparent pl-9 pr-3 py-3 text-sm placeholder-gray-400 outline-none focus:border-gray-900 transition-colors" />
        </div>
        <p class="text-red-500 text-xs mt-1.5 hidden" id="email-error"></p>
      </div>

      <button id="submitBtn" type="submit" class="w-full bg-gray-900 text-white py-3 rounded-lg text-sm font-medium hover:bg-gray-700 active:scale-[0.98] transition-all disabled:opacity-40 disabled:cursor-not-allowed mt-2">
        Send
      </button>

    </form>

    <p class="mt-8 text-center text-xs text-gray-400">
      Go back to <a href="/log-in" class="text-gray-700 font-medium hover:underline">Login</a>
    </p>

  </div>
</div>

<script>
  document.getElementById('email-form').addEventListener('submit', async (event) => {
    event.preventDefault();

    submitBtn.disabled = true;

    const data = Object.fromEntries(new FormData(event.target));
    const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

    const el = document.getElementById('email-error');
    el.textContent = '';
    el.classList.add('hidden');

    try {
      const res = await axios.post('/verify-email', data, {
        headers: {
          'x-csrf-token': csrfToken
        }
      });

      Swal.fire({
        icon: 'success',
        text: 'Reset link sent, Check your email.',
        showConfirmButton: false,
        timer: 1500,
        toast: true,
        position: 'bottom-end'
      }).then(() => {
        window.location.href = res.data?.redirect || '/log-in';
      });

    } catch (err) {

      if (err.response?.status === 429) {
        Swal.fire({
          icon: 'error',
          text: err.response?.data?.errors?.general?.[0] || 'Please wait and try again.',
          toast: true,
          position: 'bottom-end',
          showConfirmButton: false,
          timer: 4000
        });
        return;
      }

      console.log(err.response)

      const errors = err.response?.data?.errors;

      if (errors) {
        Object.keys(errors).forEach(field => {
          const el = document.getElementById(`${field}-error`);
          if (el) {
            el.textContent = errors[field];
            el.classList.remove('hidden');
          }
        });
      }

      Swal.fire({
        icon: 'error',
        text: 'Please enter valid credentials.',
        toast: true,
        position: 'bottom-end',
        showConfirmButton: false,
        timer: 3000
      });

    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
