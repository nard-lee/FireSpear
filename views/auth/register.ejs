<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="w-full max-w-md px-8">

    <div class="mb-10">
      <p class="text-xs uppercase tracking-widest text-gray-400 mb-2">Get started</p>
      <h1 class="text-4xl font-semibold text-gray-900">Create account</h1>
    </div>

    <form id="register-form" class="space-y-7">
      <div>
        <label class="block text-xs font-medium uppercase tracking-wider text-gray-800 mb-2">Name</label>
        <div class="relative">
          <i class="fa-solid fa-user absolute left-3 top-1/2 -translate-y-1/2 text-gray-800 text-sm"></i>
          <input type="text" name="name" placeholder="John Doe" class="w-full border-b border-gray-400 bg-transparent pl-9 pr-3 py-3 text-sm placeholder-gray-400 outline-none focus:border-gray-900 transition-colors" />
        </div>
        <p class="text-red-500 text-xs mt-1.5 hidden" id="name-error"></p>
      </div>

      <div>
        <label class="block text-xs font-medium uppercase tracking-wider text-gray-800 mb-2">Email</label>
        <div class="relative">
          <i class="fa-solid fa-at absolute left-3 top-1/2 -translate-y-1/2 text-gray-800 text-sm"></i>
          <input type="email" name="email" placeholder="you@example.com" class="w-full border-b border-gray-400 bg-transparent pl-9 pr-3 py-3 text-sm placeholder-gray-400 outline-none focus:border-gray-900 transition-colors" />
        </div>
        <p class="text-red-500 text-xs mt-1.5 hidden" id="email-error"></p>
      </div>

      <div>
        <label class="block text-xs font-medium uppercase tracking-wider text-gray-800 mb-2">Password</label>
        <div class="relative">
          <i class="fa-solid fa-lock absolute left-3 top-1/2 -translate-y-1/2 text-gray-800 text-sm"></i>
          <input type="password" name="password" placeholder="••••••••" class="w-full border-b border-gray-400 bg-transparent pl-9 pr-3 py-3 text-sm placeholder-gray-400 outline-none focus:border-gray-900 transition-colors" />
        </div>
        <p class="text-red-500 text-xs mt-1.5 hidden" id="password-error"></p>
      </div>

      <div>
        <label class="block text-xs font-medium uppercase tracking-wider text-gray-800 mb-2">Confirm Password</label>
        <div class="relative">
          <i class="fa-solid fa-lock absolute left-3 top-1/2 -translate-y-1/2 text-gray-800 text-sm"></i>
          <input type="password" name="confirmPassword" placeholder="••••••••" class="w-full border-b border-gray-400 bg-transparent pl-9 pr-3 py-3 text-sm placeholder-gray-400 outline-none focus:border-gray-900 transition-colors" />
        </div>
        <p class="text-red-500 text-xs mt-1.5 hidden" id="confirmPassword-error"></p>
      </div>

      <button type="button" onclick="window.location.href='/auth/google'" class="w-full flex items-center justify-center gap-3 border border-gray-300 py-3 rounded-lg text-sm font-medium text-gray-800 hover:bg-gray-100 active:scale-[0.98] transition-all">
        <svg class="w-4 h-4" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" />
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        Continue with Google
      </button>

      <div class="flex items-center gap-3">
        <div class="flex-1 border-t border-gray-300"></div>
        <span class="text-xs text-gray-400 uppercase tracking-wider">or</span>
        <div class="flex-1 border-t border-gray-300"></div>
      </div>

      <button type="submit" class="w-full bg-gray-900 text-white py-3 rounded-lg text-sm font-medium hover:bg-gray-700 active:scale-[0.98] transition-all mt-2">
        Create account
      </button>

    </form>

    <p class="mt-8 text-center text-xs text-gray-400">
      Already have an account? <a href="/log-in" class="text-gray-700 font-medium hover:underline">Sign in</a>
    </p>

  </div>
</div>

<script>
  document.getElementById('register-form').addEventListener('submit', async (event) => {
    event.preventDefault();

    const data = Object.fromEntries(new FormData(event.target));
    const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

    ['name', 'email', 'password', 'confirmPassword'].forEach(field => {
      const el = document.getElementById(`${field}-error`);
      el.textContent = '';
      el.classList.add('hidden');
    });

    try {
      const res = await axios.post('/register', data, {
        headers: {
          'x-csrf-token': csrfToken
        }
      });

      Swal.fire({
        icon: 'success',
        text: 'Account created, redirecting.',
        showConfirmButton: false,
        timer: 1500,
        toast: true,
        position: 'bottom-end'
      }).then(() => {
        window.location.href = res.data?.redirect || '/log-in';
      });;

    } catch (err) {

      if (err.response?.status === 429) {
        Swal.fire({
          icon: 'error',
          text: err.response?.data?.errors?.general?.[0] || 'Please wait and try again.',
          toast: true,
          position: 'bottom-end',
          showConfirmButton: false,
          timer: 4000
        });
        return;
      }

      const errors = err.response?.data.errors;

      if (errors) {
        Object.keys(errors).forEach(field => {
          const el = document.getElementById(`${field}-error`);
          if (el) {
            el.textContent = errors[field];
            el.classList.remove('hidden');
          }
        });
      }

      Swal.fire({
        icon: 'error',
        text: 'Please fix the errors above.',
        toast: true,
        position: 'bottom-end',
        showConfirmButton: false,
        timer: 3000
      });
    }
  });
</script>