        <i class="fa-solid fa-arrow-right text-[11px]"></i>
      </a>
      <a href="/login" class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium text-stone-600 bg-white border border-stone-200 hover:bg-stone-50 transition-colors no-underline">
        Log in to your account
      </a>
    </div>
  </div>

  <%# Feature pills %>
  <div class="flex items-center justify-center gap-3 pb-16 flex-wrap px-4">
    <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-stone-200 text-[13px] text-stone-500">
      <i class="fa-solid fa-users text-[11px] text-stone-400"></i>
