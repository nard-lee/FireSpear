    <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-stone-200 text-[13px] text-stone-500">
      <i class="fa-solid fa-chart-simple text-[11px] text-stone-400"></i>
      Activity tracking
    </div>
