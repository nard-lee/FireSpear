        </a>
      </div>
    </div>
  </nav>

  <%# Hero %>
  <div class="flex-1 flex flex-col items-center justify-center px-4 py-24 text-center">
    <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6 shadow-sm" style="background: #E24B4A;">
      <i class="fa-solid fa-fire text-white text-xl"></i>
    </div>
    <h1 class="text-4xl font-semibold text-stone-900 tracking-tight mb-4">Manage your community<br>with confidence</h1>
    <p class="text-base text-stone-400 max-w-md mb-10 leading-relaxed">FireSpear gives you the tools to manage users, moderate content, and keep your platform running smoothly — all in one place.</p>
    <div class="flex items-center gap-3">
      <a href="/signup" class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium text-white transition-colors no-underline" style="background: #E24B4A;">
