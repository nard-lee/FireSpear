  <%# Footer %>
  <div class="border-t border-stone-200 py-5 px-8">
    <div class="max-w-5xl mx-auto flex items-center justify-between">
      <span class="text-xs text-stone-400">© 2024 FireSpear. All rights reserved.</span>
      <div class="flex items-center gap-4 text-xs text-stone-400">
        <a href="#" class="hover:text-stone-600 transition-colors no-underline">Privacy</a>
        <a href="#" class="hover:text-stone-600 transition-colors no-underline">Terms</a>
      </div>
    </div>
