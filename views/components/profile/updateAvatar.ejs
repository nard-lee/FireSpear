<div class="rounded-2xl p-5 mb-4 flex items-center gap-4" style="background: #1c1917;">
  <div class="relative shrink-0 group cursor-pointer" onclick="document.getElementById('avatar-input').click()">
    <% if (user.avatar) { %>
    <img id="avatar-preview" src="<%= user.avatar %>" class="w-14 h-14 rounded-full object-cover" alt="<%= user.name %>" />
    <% } else { %>
    <div id="avatar-preview" class="w-14 h-14 rounded-full flex items-center justify-center text-[15px] font-medium text-white" style="background: #E24B4A;">
      <%= user.name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2) %>
    </div>
    <% } %>
    <div class="absolute inset-0 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
      <i class="fa-solid fa-camera text-white text-xs"></i>
    </div>
  </div>
  <input id="avatar-input" type="file" accept="image/*" class="hidden" onchange="updateAvatar(this)" />

  <div class="flex-1 min-w-0">
    <p class="text-[14px] font-medium text-stone-100 truncate"><%= user.name %></p>
    <p class="text-[13px] text-stone-500 truncate"><%= user.email %></p>
  </div>

  <% if (user.googleId) { %>
  <div class="flex items-center gap-1.5 rounded-full px-3 py-1.5 shrink-0 border border-white/[0.08]" style="background: rgba(255,255,255,0.04);">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" />
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
    </svg>
    <span class="text-[12px] text-stone-400 font-medium">Google</span>
  </div>
  <% } %>
</div>

<script>
  async function updateAvatar(input) {
    const file = input.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) {
      toast('error', 'Image must be under 2MB.');
      return;
    }
    const reader = new FileReader();
    reader.onload = event => {
      const preview = document.getElementById('avatar-preview');
      if (preview.tagName === 'IMG') {
        preview.src = event.target.result;
      } else {
        const img = document.createElement('img');
        img.id = 'avatar-preview';
        img.src = event.target.result;
        img.className = 'w-14 h-14 rounded-full object-cover';
        preview.replaceWith(img);
      }
    };
    reader.readAsDataURL(file);
    const formData = new FormData();
    formData.append('avatar', file);
    try {
      await axios.patch('/profile/avatar', formData, {
        headers: { 'x-csrf-token': csrfToken }
      });
      toast('success', 'Profile picture updated.');
    } catch (err) {
      toast('error', 'Failed to upload image. Please try again.');
    }
    input.value = '';
  }
</script>