<div class="rounded-2xl overflow-hidden border border-red-500/10" style="background: #1c1917;">
  <div class="px-5 py-4 border-b border-red-500/10">
    <p class="text-[10px] uppercase tracking-widest text-red-500/50 mb-0.5">Danger zone</p>
    <p class="text-[13px] text-stone-500">Permanently delete your account and all associated data. This cannot be undone.</p>
  </div>
  <div class="px-5 py-3 flex justify-end">
    <button
      onclick="deleteAccount()"
      class="flex items-center gap-2 px-5 py-2 rounded-xl text-[13px] font-medium text-red-500 border border-red-500/20 bg-transparent cursor-pointer transition-all active:scale-[0.98] hover:bg-red-500/10"
    >
      Delete account
    </button>
  </div>
</div>

<script>
  async function deleteAccount() {
    const { isConfirmed } = await Swal.fire({
      title: 'Delete account?',
      text: 'This will permanently delete your account and all data. This cannot be undone.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Yes, delete',
      confirmButtonColor: '#E24B4A',
      cancelButtonText: 'Cancel',
      background: '#1c1917',
      color: '#e7e5e4',
    });
    if (!isConfirmed) return;
    try {
      await axios.delete('/profile', {
        headers: { 'x-csrf-token': csrfToken },
      });
      window.location.href = '/register';
    } catch (err) {
      toast('error', 'Failed to delete account. Please try again.');
    }
  }
</script>