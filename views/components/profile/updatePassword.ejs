<% if (!user.googleId) { %>
<div class="rounded-2xl overflow-hidden mb-4" style="background: #1c1917;">
  <div class="px-5 py-4 border-b border-white/[0.06]">
    <p class="text-[10px] uppercase tracking-widest text-stone-600 mb-0.5">Password</p>
    <p class="text-[13px] text-stone-500">Must be at least 8 characters long.</p>
  </div>
  <div class="px-5 py-4 border-b border-white/[0.06] flex flex-col gap-3">
    <div>
      <input id="current-password" type="password" placeholder="Current password"
        class="w-full rounded-xl px-3 py-2.5 text-[13px] text-stone-200 placeholder-stone-600 outline-none border-none transition-colors"
        style="background: #292524;" />
      <p class="text-red-500 text-[12px] mt-1.5 hidden" id="currentPassword-error"></p>
    </div>
    <div>
      <input id="new-password" type="password" placeholder="New password"
        class="w-full rounded-xl px-3 py-2.5 text-[13px] text-stone-200 placeholder-stone-600 outline-none border-none transition-colors"
        style="background: #292524;" />
      <p class="text-red-500 text-[12px] mt-1.5 hidden" id="password-error"></p>
    </div>
    <div>
      <input id="confirm-password" type="password" placeholder="Confirm new password"
        class="w-full rounded-xl px-3 py-2.5 text-[13px] text-stone-200 placeholder-stone-600 outline-none border-none transition-colors"
        style="background: #292524;" />
      <p class="text-red-500 text-[12px] mt-1.5 hidden" id="confirmPassword-error"></p>
    </div>
  </div>
  <div class="px-5 py-3 flex justify-end">
    <button
      id="save-password-btn"
      onclick="updatePassword()"
      class="flex items-center gap-2 px-5 py-2 rounded-xl text-[13px] font-medium text-white border-none cursor-pointer transition-all active:scale-[0.98] disabled:opacity-40 disabled:cursor-not-allowed"
      style="background: #E24B4A;"
    >
      Change password
    </button>
  </div>
</div>
<% } %>

<script>
  async function updatePassword() {
    const btn = document.getElementById('save-password-btn');
    clearErrors(['currentPassword', 'password', 'confirmPassword']);
    btn.disabled = true;
    try {
      await axios.patch('/profile/password', {
        currentPassword: document.getElementById('current-password').value,
        password: document.getElementById('new-password').value,
        confirmPassword: document.getElementById('confirm-password').value,
      }, {
        headers: { 'x-csrf-token': csrfToken }
      });
      toast('success', 'Password changed successfully.');
      ['current-password', 'new-password', 'confirm-password'].forEach(id => document.getElementById(id).value = '');
    } catch (err) {
      if (err.response?.data?.errors)
        showErrors(err.response.data.errors);
      else toast('error', 'Something went wrong. Please try again.');
    } finally {
      btn.disabled = false;
    }
  }
</script>